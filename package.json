{
  "name": "substack-downloader",
  "version": "1.1.0",
  "description": "Download all articles from any Substack site and generate a PDF ebook with table of contents",
  "type": "module",
  "main": "src/substack_downloader.js",
  "bin": {
    "substack-downloader": "./src/substack_downloader.js",
    "substack-epub": "./src/substack_epub.js"
  },
  "scripts": {
    "start": "node src/substack_downloader.js",
    "epub": "node src/substack_epub.js",
    "cli": "node src/cli.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "substack",
    "downloader",
    "pdf",
    "scraper",
    "ebook",
    "archive",
    "backup",
    "puppeteer",
    "chrome",
    "automation"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wayhome/substack-downloader.git"
  },
  "bugs": {
    "url": "https://github.com/wayhome/substack-downloader/issues"
  },
  "homepage": "https://github.com/wayhome/substack-downloader#readme",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "epub-gen": "^0.1.0",
    "puppeteer-core": "^21.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "prettier": "^3.0.0"
  }
}
